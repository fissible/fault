{
    "name": "fissible/fault",
    "description": "Exception tracking and triage for fissible/watch cockpit",
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/fissible/fault",
    "keywords": ["laravel", "exceptions", "tracking", "triage", "devtools", "watch"],
    "authors": [
        {
            "name": "Allen McCabe",
            "homepage": "https://github.com/allenmccabe"
        }
    ],
    "require": {
        "php": "^8.2",
        "fissible/watch": "^1.0",
        "illuminate/contracts": "^11.0|^12.0",
        "illuminate/database": "^11.0|^12.0",
        "illuminate/http": "^11.0|^12.0",
        "illuminate/routing": "^11.0|^12.0",
        "illuminate/support": "^11.0|^12.0",
        "illuminate/view": "^11.0|^12.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "orchestra/testbench": "^9.0"
    },
    "autoload": {
        "psr-4": {
            "Fissible\\Fault\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Fissible\\Fault\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Fissible\\Fault\\Providers\\FaultServiceProvider"
            ]
        }
    },
    "suggest": {
        "filament/filament": "Required for the Filament admin plugin (^5.0)"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "repositories": {
        "watch": {
            "type": "vcs",
            "url": "https://github.com/fissible/watch"
        },
        "accord": {
            "type": "vcs",
            "url": "https://github.com/fissible/accord"
        },
        "drift": {
            "type": "vcs",
            "url": "https://github.com/fissible/drift"
        },
        "forge": {
            "type": "vcs",
            "url": "https://github.com/fissible/forge"
        }
    }
}
